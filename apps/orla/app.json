{
  "expo": {
    "name": "Orla",
    "slug": "orla",
    "version": "0.1.0",
    "scheme": "orla",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.heyorla"
    },
    "web": {
      "bundler": "metro"
    },
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Orla to attach photos to your conversations."
        }
      ]
    ]
  }
}
